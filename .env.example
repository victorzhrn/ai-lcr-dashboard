# Storage (required) — a Postgres connection string you provide.
# Any Postgres works: Neon, Supabase, RDS, local, etc. Then run `npm run db:init`.
# (Optional shortcut if you have no DB: `npm i get-db9 && npm run db:provision:db9`.)
DATABASE_URL=

# Write door (optional). If set, POST /api/ingest requires:
#   Authorization: Bearer <INGEST_KEY>
# A leaked write key lets someone write rows, not read them.
INGEST_KEY=

# Read door (optional). If set, viewing the dashboard requires HTTP Basic auth
# (any username, this as the password). Leave empty for an open, single-user box.
DASHBOARD_PASSWORD=
